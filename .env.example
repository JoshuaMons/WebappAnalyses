# Required for Vercel deployment.
# URL to a publicly accessible .db file (Vercel Blob, R2, S3, etc.).
# Vercel does not pull Git LFS files, so this variable is mandatory for the
# dashboard to load data when deployed online.
SUPPORT_ANALYTICS_DB_URL=https://your-host.example.com/your-database.db

# Optional: server-side OpenAI proxy.
# When set, AI enrichment requests are routed through /api/ai-enrich instead
# of being sent directly from the browser, avoiding CORS issues.
OPENAI_API_KEY=sk-...
