# SQLite database files — not committed.
# On Vercel, set SUPPORT_ANALYTICS_DB_URL to point to a hosted .db file.
# For local development, place your .db file in /data/ manually.
data/*.db
data/*.db-wal
data/*.db-shm
data/*.db-journal

# Data exports / uploads — may contain sensitive customer data
data/*.xlsx
data/*.xls
data/*.csv

# Environment variables
.env
.env.local
.env.production

# OS / editor
.DS_Store
Thumbs.db

# Codex push temp files
.codex-push-tmp/

# Test / large binary files
data/*.bin
data/*.txt
